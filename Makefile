# BDD-TDD Template Makefile

.PHONY: help

help:
	@echo "AI-BDD-TDD-Template Makefile"
	@echo "프로젝트에 맞게 명령어를 확장하세요."
	@echo ""
	@echo "Usage:"
	@echo "  make test      - 모든 테스트 실행 (구현 필요)"
	@echo "  make dev       - 개발 서버 실행 (구현 필요)"

test:
	@echo "테스트 스크립트가 아직 연결되지 않았습니다."

dev:
	@echo "개발 서버 스크립트가 아직 연결되지 않았습니다."
